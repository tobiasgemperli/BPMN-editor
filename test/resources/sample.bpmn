<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://example.com/bpmn">
  <bpmn:process id="Process_1" isExecutable="false">
    <bpmn:startEvent id="start_1" name="Begin"/>
    <bpmn:task id="task_1" name="Review Document"/>
    <bpmn:exclusiveGateway id="gateway_1" name="Approved?"/>
    <bpmn:task id="task_2" name="Publish"/>
    <bpmn:task id="task_3" name="Revise"/>
    <bpmn:endEvent id="end_1" name="Done"/>
    <bpmn:sequenceFlow id="flow_1" sourceRef="start_1" targetRef="task_1"/>
    <bpmn:sequenceFlow id="flow_2" sourceRef="task_1" targetRef="gateway_1"/>
    <bpmn:sequenceFlow id="flow_3" sourceRef="gateway_1" targetRef="task_2" name="Yes"/>
    <bpmn:sequenceFlow id="flow_4" sourceRef="gateway_1" targetRef="task_3" name="No"/>
    <bpmn:sequenceFlow id="flow_5" sourceRef="task_2" targetRef="end_1"/>
    <bpmn:sequenceFlow id="flow_6" sourceRef="task_3" targetRef="task_1"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="start_1_di" bpmnElement="start_1">
        <dc:Bounds x="100" y="200" width="48" height="48"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_1_di" bpmnElement="task_1">
        <dc:Bounds x="230" y="189" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_1_di" bpmnElement="gateway_1">
        <dc:Bounds x="440" y="196" width="56" height="56"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_2_di" bpmnElement="task_2">
        <dc:Bounds x="570" y="189" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_3_di" bpmnElement="task_3">
        <dc:Bounds x="570" y="320" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_1_di" bpmnElement="end_1">
        <dc:Bounds x="780" y="200" width="48" height="48"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_1_di" bpmnElement="flow_1">
        <di:waypoint x="148" y="224"/>
        <di:waypoint x="230" y="224"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_2_di" bpmnElement="flow_2">
        <di:waypoint x="370" y="224"/>
        <di:waypoint x="440" y="224"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_3_di" bpmnElement="flow_3">
        <di:waypoint x="496" y="224"/>
        <di:waypoint x="570" y="224"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_4_di" bpmnElement="flow_4">
        <di:waypoint x="468" y="252"/>
        <di:waypoint x="468" y="355"/>
        <di:waypoint x="570" y="355"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_5_di" bpmnElement="flow_5">
        <di:waypoint x="710" y="224"/>
        <di:waypoint x="780" y="224"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_6_di" bpmnElement="flow_6">
        <di:waypoint x="570" y="355"/>
        <di:waypoint x="300" y="355"/>
        <di:waypoint x="300" y="259"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
