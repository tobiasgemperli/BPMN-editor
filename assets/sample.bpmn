<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://example.com/bpmn">
  <bpmn:process id="Process_1" isExecutable="false">

    <bpmn:startEvent id="start_1" name="Start"/>
    <bpmn:task id="task_workshop" name="Rapid Prototyping Workshop with Milk"/>
    <bpmn:exclusiveGateway id="gw_proceed" name="Proceed?"/>
    <bpmn:endEvent id="end_no" name="End"/>
    <bpmn:task id="task_s1" name="Sprint 1"/>
    <bpmn:task id="task_s2" name="Sprint 2"/>
    <bpmn:task id="task_s3" name="Sprint 3"/>
    <bpmn:task id="task_s4" name="Sprint 4"/>
    <bpmn:task id="task_s5" name="Sprint 5"/>
    <bpmn:exclusiveGateway id="gw_usertests" name="User Tests"/>
    <bpmn:endEvent id="end_launch" name="Product Launch"/>
    <bpmn:exclusiveGateway id="gw_budget" name="More Budget?"/>
    <bpmn:endEvent id="end_nobudget" name="End"/>
    <bpmn:task id="task_s6" name="Sprint 6"/>
    <bpmn:task id="task_s7" name="Sprint 7"/>
    <bpmn:task id="task_s8" name="Sprint 8"/>
    <bpmn:endEvent id="end_launch2" name="Product Launch"/>

    <bpmn:sequenceFlow id="flow_1" sourceRef="start_1" targetRef="task_workshop"/>
    <bpmn:sequenceFlow id="flow_2" sourceRef="task_workshop" targetRef="gw_proceed"/>
    <bpmn:sequenceFlow id="flow_no" sourceRef="gw_proceed" targetRef="end_no" name="No"/>
    <bpmn:sequenceFlow id="flow_yes" sourceRef="gw_proceed" targetRef="task_s1" name="Yes"/>
    <bpmn:sequenceFlow id="flow_s1s2" sourceRef="task_s1" targetRef="task_s2"/>
    <bpmn:sequenceFlow id="flow_s2s3" sourceRef="task_s2" targetRef="task_s3"/>
    <bpmn:sequenceFlow id="flow_s3s4" sourceRef="task_s3" targetRef="task_s4"/>
    <bpmn:sequenceFlow id="flow_s4s5" sourceRef="task_s4" targetRef="task_s5"/>
    <bpmn:sequenceFlow id="flow_s5gw" sourceRef="task_s5" targetRef="gw_usertests"/>
    <bpmn:sequenceFlow id="flow_good" sourceRef="gw_usertests" targetRef="end_launch" name="Good"/>
    <bpmn:sequenceFlow id="flow_notgood" sourceRef="gw_usertests" targetRef="gw_budget" name="Not Good"/>
    <bpmn:sequenceFlow id="flow_nobudget" sourceRef="gw_budget" targetRef="end_nobudget" name="No"/>
    <bpmn:sequenceFlow id="flow_yesbudget" sourceRef="gw_budget" targetRef="task_s6" name="Yes"/>
    <bpmn:sequenceFlow id="flow_s6s7" sourceRef="task_s6" targetRef="task_s7"/>
    <bpmn:sequenceFlow id="flow_s7s8" sourceRef="task_s7" targetRef="task_s8"/>
    <bpmn:sequenceFlow id="flow_s8end" sourceRef="task_s8" targetRef="end_launch2"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">

      <!-- Main vertical flow centered at x=180 -->
      <bpmndi:BPMNShape id="start_1_di" bpmnElement="start_1">
        <dc:Bounds x="156" y="40" width="48" height="48"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_workshop_di" bpmnElement="task_workshop">
        <dc:Bounds x="90" y="130" width="180" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_proceed_di" bpmnElement="gw_proceed">
        <dc:Bounds x="152" y="244" width="56" height="56"/>
      </bpmndi:BPMNShape>

      <!-- No: branch right to End -->
      <bpmndi:BPMNShape id="end_no_di" bpmnElement="end_no">
        <dc:Bounds x="320" y="248" width="48" height="48"/>
      </bpmndi:BPMNShape>

      <!-- Yes: continue down -->
      <bpmndi:BPMNShape id="task_s1_di" bpmnElement="task_s1">
        <dc:Bounds x="110" y="350" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s2_di" bpmnElement="task_s2">
        <dc:Bounds x="110" y="460" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s3_di" bpmnElement="task_s3">
        <dc:Bounds x="110" y="570" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s4_di" bpmnElement="task_s4">
        <dc:Bounds x="110" y="680" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s5_di" bpmnElement="task_s5">
        <dc:Bounds x="110" y="790" width="140" height="70"/>
      </bpmndi:BPMNShape>

      <!-- User Tests gateway -->
      <bpmndi:BPMNShape id="gw_usertests_di" bpmnElement="gw_usertests">
        <dc:Bounds x="152" y="910" width="56" height="56"/>
      </bpmndi:BPMNShape>

      <!-- Good: branch right to Product Launch -->
      <bpmndi:BPMNShape id="end_launch_di" bpmnElement="end_launch">
        <dc:Bounds x="320" y="914" width="48" height="48"/>
      </bpmndi:BPMNShape>

      <!-- Not Good: continue down to More Budget? -->
      <bpmndi:BPMNShape id="gw_budget_di" bpmnElement="gw_budget">
        <dc:Bounds x="152" y="1020" width="56" height="56"/>
      </bpmndi:BPMNShape>

      <!-- No budget: branch right to End -->
      <bpmndi:BPMNShape id="end_nobudget_di" bpmnElement="end_nobudget">
        <dc:Bounds x="320" y="1024" width="48" height="48"/>
      </bpmndi:BPMNShape>

      <!-- Yes budget: continue down through Sprints 6-8 -->
      <bpmndi:BPMNShape id="task_s6_di" bpmnElement="task_s6">
        <dc:Bounds x="110" y="1126" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s7_di" bpmnElement="task_s7">
        <dc:Bounds x="110" y="1236" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s8_di" bpmnElement="task_s8">
        <dc:Bounds x="110" y="1346" width="140" height="70"/>
      </bpmndi:BPMNShape>

      <!-- Final Product Launch -->
      <bpmndi:BPMNShape id="end_launch2_di" bpmnElement="end_launch2">
        <dc:Bounds x="156" y="1466" width="48" height="48"/>
      </bpmndi:BPMNShape>

      <!-- Vertical edges (main flow) -->
      <bpmndi:BPMNEdge id="flow_1_di" bpmnElement="flow_1">
        <di:waypoint x="180" y="88"/>
        <di:waypoint x="180" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_2_di" bpmnElement="flow_2">
        <di:waypoint x="180" y="200"/>
        <di:waypoint x="180" y="244"/>
      </bpmndi:BPMNEdge>

      <!-- No: right from gateway to End -->
      <bpmndi:BPMNEdge id="flow_no_di" bpmnElement="flow_no">
        <di:waypoint x="208" y="272"/>
        <di:waypoint x="320" y="272"/>
      </bpmndi:BPMNEdge>

      <!-- Yes: down from gateway to Sprint 1 -->
      <bpmndi:BPMNEdge id="flow_yes_di" bpmnElement="flow_yes">
        <di:waypoint x="180" y="300"/>
        <di:waypoint x="180" y="350"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_s1s2_di" bpmnElement="flow_s1s2">
        <di:waypoint x="180" y="420"/>
        <di:waypoint x="180" y="460"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s2s3_di" bpmnElement="flow_s2s3">
        <di:waypoint x="180" y="530"/>
        <di:waypoint x="180" y="570"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s3s4_di" bpmnElement="flow_s3s4">
        <di:waypoint x="180" y="640"/>
        <di:waypoint x="180" y="680"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s4s5_di" bpmnElement="flow_s4s5">
        <di:waypoint x="180" y="750"/>
        <di:waypoint x="180" y="790"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s5gw_di" bpmnElement="flow_s5gw">
        <di:waypoint x="180" y="860"/>
        <di:waypoint x="180" y="910"/>
      </bpmndi:BPMNEdge>

      <!-- Good: right to Product Launch -->
      <bpmndi:BPMNEdge id="flow_good_di" bpmnElement="flow_good">
        <di:waypoint x="208" y="938"/>
        <di:waypoint x="320" y="938"/>
      </bpmndi:BPMNEdge>

      <!-- Not Good: down to budget gateway -->
      <bpmndi:BPMNEdge id="flow_notgood_di" bpmnElement="flow_notgood">
        <di:waypoint x="180" y="966"/>
        <di:waypoint x="180" y="1020"/>
      </bpmndi:BPMNEdge>

      <!-- No budget: right to End -->
      <bpmndi:BPMNEdge id="flow_nobudget_di" bpmnElement="flow_nobudget">
        <di:waypoint x="208" y="1048"/>
        <di:waypoint x="320" y="1048"/>
      </bpmndi:BPMNEdge>

      <!-- Yes budget: down to Sprint 6 -->
      <bpmndi:BPMNEdge id="flow_yesbudget_di" bpmnElement="flow_yesbudget">
        <di:waypoint x="180" y="1076"/>
        <di:waypoint x="180" y="1126"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="flow_s6s7_di" bpmnElement="flow_s6s7">
        <di:waypoint x="180" y="1196"/>
        <di:waypoint x="180" y="1236"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s7s8_di" bpmnElement="flow_s7s8">
        <di:waypoint x="180" y="1306"/>
        <di:waypoint x="180" y="1346"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s8end_di" bpmnElement="flow_s8end">
        <di:waypoint x="180" y="1416"/>
        <di:waypoint x="180" y="1466"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
