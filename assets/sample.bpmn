<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://example.com/bpmn">
  <bpmn:process id="Process_1" isExecutable="false">

    <bpmn:startEvent id="start_1" name="Start"/>
    <bpmn:task id="task_s1" name="Sprint 1"/>
    <bpmn:exclusiveGateway id="gw_proceed" name="Proceed?"/>
    <bpmn:endEvent id="end_no" name="End"/>
    <bpmn:task id="task_s2" name="Sprint 2"/>
    <bpmn:task id="task_s3" name="Sprint 3"/>
    <bpmn:task id="task_s4" name="Sprint 4"/>
    <bpmn:exclusiveGateway id="gw_usertests" name="User Tests"/>
    <bpmn:endEvent id="end_launch" name="Product Launch"/>
    <bpmn:task id="task_s5" name="Sprint 5"/>
    <bpmn:endEvent id="end_launch2" name="Product Launch"/>

    <bpmn:sequenceFlow id="flow_start" sourceRef="start_1" targetRef="task_s1"/>
    <bpmn:sequenceFlow id="flow_s1gw" sourceRef="task_s1" targetRef="gw_proceed"/>
    <bpmn:sequenceFlow id="flow_no" sourceRef="gw_proceed" targetRef="end_no" name="No"/>
    <bpmn:sequenceFlow id="flow_yes" sourceRef="gw_proceed" targetRef="task_s2" name="Yes"/>
    <bpmn:sequenceFlow id="flow_s2s3" sourceRef="task_s2" targetRef="task_s3"/>
    <bpmn:sequenceFlow id="flow_s3s4" sourceRef="task_s3" targetRef="task_s4"/>
    <bpmn:sequenceFlow id="flow_s4gw" sourceRef="task_s4" targetRef="gw_usertests"/>
    <bpmn:sequenceFlow id="flow_good" sourceRef="gw_usertests" targetRef="end_launch" name="Good"/>
    <bpmn:sequenceFlow id="flow_improve" sourceRef="gw_usertests" targetRef="task_s5" name="Needs Improvement"/>
    <bpmn:sequenceFlow id="flow_s5end" sourceRef="task_s5" targetRef="end_launch2"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">

      <bpmndi:BPMNShape id="start_1_di" bpmnElement="start_1">
        <dc:Bounds x="156" y="40" width="48" height="48"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s1_di" bpmnElement="task_s1">
        <dc:Bounds x="80" y="130" width="200" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gw_proceed_di" bpmnElement="gw_proceed">
        <dc:Bounds x="152" y="244" width="56" height="56"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_no_di" bpmnElement="end_no">
        <dc:Bounds x="320" y="248" width="48" height="48"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_s2_di" bpmnElement="task_s2">
        <dc:Bounds x="110" y="350" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s3_di" bpmnElement="task_s3">
        <dc:Bounds x="110" y="460" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_s4_di" bpmnElement="task_s4">
        <dc:Bounds x="110" y="570" width="140" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="gw_usertests_di" bpmnElement="gw_usertests">
        <dc:Bounds x="152" y="690" width="56" height="56"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_launch_di" bpmnElement="end_launch">
        <dc:Bounds x="320" y="694" width="48" height="48"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="task_s5_di" bpmnElement="task_s5">
        <dc:Bounds x="110" y="796" width="140" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_launch2_di" bpmnElement="end_launch2">
        <dc:Bounds x="156" y="916" width="48" height="48"/>
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="flow_start_di" bpmnElement="flow_start">
        <di:waypoint x="180" y="88"/>
        <di:waypoint x="180" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s1gw_di" bpmnElement="flow_s1gw">
        <di:waypoint x="180" y="200"/>
        <di:waypoint x="180" y="244"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_no_di" bpmnElement="flow_no">
        <di:waypoint x="208" y="272"/>
        <di:waypoint x="320" y="272"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_yes_di" bpmnElement="flow_yes">
        <di:waypoint x="180" y="300"/>
        <di:waypoint x="180" y="350"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s2s3_di" bpmnElement="flow_s2s3">
        <di:waypoint x="180" y="420"/>
        <di:waypoint x="180" y="460"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s3s4_di" bpmnElement="flow_s3s4">
        <di:waypoint x="180" y="530"/>
        <di:waypoint x="180" y="570"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s4gw_di" bpmnElement="flow_s4gw">
        <di:waypoint x="180" y="640"/>
        <di:waypoint x="180" y="690"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_good_di" bpmnElement="flow_good">
        <di:waypoint x="208" y="718"/>
        <di:waypoint x="320" y="718"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_improve_di" bpmnElement="flow_improve">
        <di:waypoint x="180" y="746"/>
        <di:waypoint x="180" y="796"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_s5end_di" bpmnElement="flow_s5end">
        <di:waypoint x="180" y="866"/>
        <di:waypoint x="180" y="916"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
